{
  "name": "edge-chat-virtualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint .",
    "playwright:install": "playwright install chromium",
    "test": "vitest run",
    "test:live": "pnpm build && cross-env LIVE_CHATGPT=1 playwright test tests/playwright/live.chatgpt.spec.ts",
    "test:playwright": "pnpm build && playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.39",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.37.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
